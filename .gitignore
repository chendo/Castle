# Secrets
.env
.env.*
!.env.example

# Local docker overrides (host aliases, dev-only port mappings, etc.)
docker-compose.override.yml
docker-compose.override.yaml

# pi-agent runtime artifacts (auth tokens, generated catalog, models.json with API keys)
.pi-agent/

# Frontend
node_modules/
web/dist/

# Logs / scratch
*.log
.DS_Store

# Local dev scratch — notes, throwaway scripts that shouldn't be tracked
workspace/

# Claude Code local session state (permissions, transcripts, scratch).
.claude/

# Playwright-MCP session artifacts (browser snapshots, screenshots from local testing)
.playwright-mcp/
# Loose screenshots at repo root or under the add-on dir — UI captures can
# leak the live HA_URL / LLM_URL shown in the drawer footer. Anchored so it
# does NOT swallow icon.png / logo.png under castle/ or tracked images deeper.
/*.png
/castle/*.png

# ha-demo runtime artifacts — Home Assistant writes these on boot, plus the
# integration tests mutate automations.yaml via the REST API. Track only the
# curated fixtures (configuration.yaml + the demo-camera.jpg etc.) and the
# `.fixture` files the runner copies into place before each test run; the
# live mutable copies are gitignored. Whitelist any new fixture explicitly.
castle/tests/integration/ha-demo-config/*
!castle/tests/integration/ha-demo-config/configuration.yaml
!castle/tests/integration/ha-demo-config/demo-camera.jpg
!castle/tests/integration/ha-demo-config/automations.yaml.fixture
!castle/tests/integration/ha-demo-config/.gitkeep
