# Secrets
.env
.env.*
!.env.example

# Local docker overrides (host aliases, dev-only port mappings, etc.)
docker-compose.override.yml
docker-compose.override.yaml

# pi-agent runtime artifacts (auth tokens, generated catalog, models.json with API keys)
.pi-agent/

# Frontend
node_modules/
web/dist/

# Logs / scratch
*.log
.DS_Store

# Local dev scratch — notes, throwaway scripts that shouldn't be tracked
workspace/

# Playwright-MCP session artifacts (browser snapshots, screenshots from local testing)
.playwright-mcp/
topbar.png

# ha-demo runtime artifacts — Home Assistant writes these on boot. Track only
# the curated fixtures (configuration.yaml + the demo-camera.jpg etc.) and
# whitelist any new fixture explicitly.
tests/integration/ha-demo-config/*
!tests/integration/ha-demo-config/configuration.yaml
!tests/integration/ha-demo-config/demo-camera.jpg
!tests/integration/ha-demo-config/automations.yaml
!tests/integration/ha-demo-config/.gitkeep
