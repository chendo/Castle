# Copy to .env and fill in. Never commit the .env file.

# --- Home Assistant ---
# Long-lived access token from HA Settings → Profile → Long-Lived Access Tokens.
# Should have write permission so the agent can read the exposed-entities list.
HA_TOKEN=

# Optional: override if HA isn't on the default mDNS hostname.
# HA_URL=http://homeassistant.local:8123

# --- Model server (any OpenAI-compatible endpoint) ---
# Examples:
#   LM Studio:   http://host.docker.internal:1234/v1
#   vLLM:        http://host.docker.internal:8000/v1
#   llama.cpp:   http://host.docker.internal:8080/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   OpenAI:      https://api.openai.com/v1
OPENAI_URL=http://host.docker.internal:1234/v1
OPENAI_API_KEY=
MODEL_NAME=

# --- Castle server ---
# Optional bearer token for Castle's HTTP/WS endpoints. Leave empty to disable auth.
# CASTLE_AUTH_TOKEN=

# Optional: external port mapping (default 7091 → container 7090).
# CASTLE_PORT=7091
